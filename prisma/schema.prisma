generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int         @id @default(autoincrement())
  username   String      @unique
  password   String
  name       String
  role       String      @default("viewer")
  createdAt     DateTime       @default(now())
  receptions    Reception[]
  majorProjects MajorProject[]
}

model Reception {
  id            Int      @id @default(autoincrement())
  startTime     DateTime
  endTime       DateTime
  title         String
  level         String
  form          String
  host          String
  dressCode     String
  purpose       String
  status        String   @default("正常")
  location      String?
  locationKey   String?
  leaders       String?
  minutes       String?
  minuteFiles   String?
  photos        String?
  todos         String?
  remark        String?
  customFields  String?
  createdById   Int
  createdBy     User     @relation(fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  notifications Notification[]
}

// 定时通知
model Notification {
  id           Int       @id @default(autoincrement())
  receptionId  Int
  reception    Reception @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  scheduledAt  DateTime
  sent         Boolean   @default(false)
  sentAt       DateTime?
  label        String?
  fields       String?   // JSON: 选中发送的字段
  targetId     Int?
  target       NotifyTarget? @relation(fields: [targetId], references: [id])
  createdAt    DateTime  @default(now())
}

// 通知目标（群机器人或个人）
model NotifyTarget {
  id            Int            @id @default(autoincrement())
  name          String         // 显示名称，如"接待工作群"
  type          String         // group_webhook | person_webhook
  webhook       String         // Webhook URL
  sortOrder     Int            @default(0)
  notifications Notification[]
}

model CustomFieldDef {
  id         Int     @id @default(autoincrement())
  fieldKey   String  @unique
  fieldLabel String
  fieldType  String
  options    String?
  required   Boolean @default(false)
  sortOrder  Int     @default(0)
  enabled    Boolean @default(true)
}

model HostPreset {
  id        Int      @id @default(autoincrement())
  name      String
  title     String?
  feishuId  String?
  avatar    String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// 待办大类（含子项）
model TodoCategory {
  id        Int        @id @default(autoincrement())
  name      String
  sortOrder Int        @default(0)
  items     TodoItem[]
}

model TodoItem {
  id         Int          @id @default(autoincrement())
  categoryId Int
  category   TodoCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  text       String
  sortOrder  Int          @default(0)
}

// 系统配置（key-value）
model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model MajorProject {
  id              Int            @id @default(autoincrement())
  name            String
  type            String         @default("其他")
  company         String?
  level           String         @default("其他")
  status          String         @default("进行中")
  totalAmount     Float?
  receivedAmount  Float          @default(0)
  owner           String?
  responsible     String?
  applyCode       String?
  star            Boolean        @default(false)
  remark          String?
  customFields    String?
  payRecords      String?
  lifeCycle       String?
  metrics         String?
  parentId        Int?
  parent          MajorProject?  @relation("ProjectChildren", fields: [parentId], references: [id])
  children        MajorProject[] @relation("ProjectChildren")
  createdById     Int
  createdBy       User           @relation(fields: [createdById], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// 落地协议模块

model AgreementData {
  id          Int      @id @default(autoincrement())
  period      String
  category    String
  payload     String
  submittedBy Int?
  lockedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([period, category])
}

model QualitativeObligation {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  name         String
  articleRef   String
  requirement  String
  status       String   @default("pending")
  description  String?
  evidenceUrls String?
  updatedById  Int?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model SubsidyApplication {
  id            Int      @id @default(autoincrement())
  code          String
  policyItem    String
  year          Int
  appliedAmount Float?
  submittedAt   DateTime?
  status        String   @default("draft")
  paidAmount    Float?
  paidAt        DateTime?
  remark        String?
  createdById   Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
