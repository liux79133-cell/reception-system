generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int         @id @default(autoincrement())
  username   String      @unique
  password   String
  name       String
  role       String      @default("viewer")
  createdAt  DateTime    @default(now())
  receptions Reception[]
}

model Reception {
  id            Int      @id @default(autoincrement())
  startTime     DateTime
  endTime       DateTime
  title         String
  level         String
  form          String
  host          String
  dressCode     String
  purpose       String
  status        String   @default("正常")
  location      String?
  locationKey   String?
  leaders       String?
  minutes       String?
  minuteFiles   String?
  photos        String?
  todos         String?
  remark        String?
  customFields  String?
  createdById   Int
  createdBy     User     @relation(fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  notifications Notification[]
}

// 定时通知
model Notification {
  id           Int       @id @default(autoincrement())
  receptionId  Int
  reception    Reception @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  scheduledAt  DateTime
  sent         Boolean   @default(false)
  sentAt       DateTime?
  label        String?
  createdAt    DateTime  @default(now())
}

model CustomFieldDef {
  id         Int     @id @default(autoincrement())
  fieldKey   String  @unique
  fieldLabel String
  fieldType  String
  options    String?
  required   Boolean @default(false)
  sortOrder  Int     @default(0)
  enabled    Boolean @default(true)
}

model HostPreset {
  id        Int      @id @default(autoincrement())
  name      String
  title     String?
  feishuId  String?
  avatar    String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// 待办大类（含子项）
model TodoCategory {
  id        Int        @id @default(autoincrement())
  name      String
  sortOrder Int        @default(0)
  items     TodoItem[]
}

model TodoItem {
  id         Int          @id @default(autoincrement())
  categoryId Int
  category   TodoCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  text       String
  sortOrder  Int          @default(0)
}
